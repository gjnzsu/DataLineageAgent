        <mxCell id="lb_l" value="B &#183; PIPELINE ORCHESTRATOR &#8212; pipeline/run_pipeline.py" style="text;html=1;align=left;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1a3f6f;" vertex="1" parent="1"><mxGeometry x="42" y="175" width="400" height="18" as="geometry" /></mxCell>

        <mxCell id="orch" value="&lt;b&gt;run_pipeline.py&lt;/b&gt; &#183; Initialises LineageTracker &amp; DuckDB &#183; Sequences Stage 0&#8594;4 &#183; Emits Prometheus counters per stage &#183; Writes data/metrics_report.json on completion &#183; Run: python -m pipeline.run_pipeline" style="text;html=1;align=left;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="420" y="175" width="1350" height="40" as="geometry" /></mxCell>

