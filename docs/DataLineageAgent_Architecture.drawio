        <mxCell id="s0" value="&lt;b&gt;Stage 0: Provider&lt;/b&gt;&lt;br/&gt;mock_provider.py&lt;br/&gt;&lt;hr/&gt;Op: PRODUCE&lt;br/&gt;Emits: RAW lineage nodes&lt;br/&gt;Output: interest_rates.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=9;" vertex="1" parent="1"><mxGeometry x="55" y="249" width="188" height="130" as="geometry" /></mxCell>

        <mxCell id="s1" value="&lt;b&gt;Stage 1: Ingest&lt;/b&gt;&lt;br/&gt;ingest.py&lt;br/&gt;&lt;hr/&gt;Op: INGEST&lt;br/&gt;Emits: INGESTED nodes&lt;br/&gt;DuckDB: CREATE bronze_rates&lt;br/&gt;INSERT rows from JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#c8820a;fontSize=9;" vertex="1" parent="1"><mxGeometry x="278" y="249" width="188" height="130" as="geometry" /></mxCell>

        <mxCell id="s2" value="&lt;b&gt;Stage 2: Validate&lt;/b&gt;&lt;br/&gt;validate.py&lt;br/&gt;&lt;hr/&gt;Op: VALIDATE&lt;br/&gt;Rules: rate_type&#183;tenor&#183;value (0-0.30)&#183;date&lt;br/&gt;Emits: VALIDATED nodes&lt;br/&gt;DuckDB: silver_rates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#888;fontSize=9;" vertex="1" parent="1"><mxGeometry x="501" y="249" width="188" height="130" as="geometry" /></mxCell>

        <mxCell id="s3" value="&lt;b&gt;Stage 3: Transform&lt;/b&gt;&lt;br/&gt;transform.py&lt;br/&gt;&lt;hr/&gt;Ops: TRANSFORM x4 per record&lt;br/&gt;1. BPS Conversion&lt;br/&gt;2. PCT Conversion&lt;br/&gt;3. Rate Classification (LOW/MED/HIGH)&lt;br/&gt;4. Tenor Normalisation&lt;br/&gt;DuckDB: UPDATE silver_rates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#888;fontSize=9;" vertex="1" parent="1"><mxGeometry x="724" y="249" width="188" height="130" as="geometry" /></mxCell>

        <mxCell id="s4" value="&lt;b&gt;Stage 4: Aggregate&lt;/b&gt;&lt;br/&gt;aggregate.py&lt;br/&gt;&lt;hr/&gt;Op: AGGREGATE&lt;br/&gt;Groups: rate_type+tenor+date&lt;br/&gt;Computes: avg, min, max&lt;br/&gt;Emits: AGGREGATED nodes&lt;br/&gt;DuckDB: gold_rates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1"><mxGeometry x="947" y="249" width="188" height="130" as="geometry" /></mxCell>

