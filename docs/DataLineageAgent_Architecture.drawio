        <mxCell id="mp" value="&lt;b&gt;MockFedProvider&lt;/b&gt; &#8212; pipeline/stages/mock_provider.py&lt;br/&gt;50 seeded records &#183; Rate Types: SOFR, LIBOR, FED_FUNDS_RATE &#183; Tenors: overnight, 1M, 3M, 6M &#183; Currency: USD &#183; ~10% bad records injected for DQ testing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1"><mxGeometry x="60" y="92" width="700" height="52" as="geometry" /></mxCell>

